# Instagram Auto-Reply Service - Environment Configuration
# =========================================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# REQUIRED: Generate secure keys:
#   openssl rand -hex 32  # For FLASK_SECRET_KEY
#   openssl rand -hex 16  # For META_VERIFY_TOKEN

# Flask Security (REQUIRED)
# -------------------------
# Minimum 32 characters required
FLASK_SECRET_KEY=your-super-secret-key-minimum-32-characters-long

# Meta App Credentials (REQUIRED)
# -------------------------------
# Get from: https://developers.facebook.com/apps/
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-random-webhook-verify-token

# OAuth Redirect URI (REQUIRED)
# -----------------------------
# Must match exactly in Meta App Dashboard
# Must use HTTPS in production
META_REDIRECT_URI=https://www.pysend.com/instagram/auth/callback

# Server Configuration
# --------------------
# FLASK_ENV determines the mode
FLASK_ENV=production
FLASK_DEBUG=false

# Note: In Docker, the server always binds to 0.0.0.0:8000
# This is configured in Dockerfile and docker-compose.yml

# Database (Optional)
# -------------------
# Default: SQLite in ./data/ directory inside container
# DATABASE_URL=sqlite:///data/instagram_service.db

# Token Encryption Salt (Optional)
# --------------------------------
# Changing this invalidates all stored tokens
# TOKEN_ENCRYPTION_SALT=your-custom-salt
