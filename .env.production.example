FLASK_SECRET_KEY=my-production-secret-key-here

# Meta App Credentials (from https://developers.facebook.com/apps/)
META_APP_ID=my-app-id
META_APP_SECRET=my-app-secret
META_REDIRECT_URI=https://mydomain.com/instagram/auth/callback
META_VERIFY_TOKEN=my-webhook-verify-token

# Production Settings
FLASK_ENV=production
FLASK_DEBUG=false
